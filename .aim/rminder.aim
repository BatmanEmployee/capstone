§4 COMPLETE FILE MAP
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ROOT
  index.php                    Landing page (login/register links)
  rminder_db.sql               Base schema + seed data
  migrate_additions.sql        Adds: users.status, announcements.category, events ongoing, attendance, forum_threads, forum_replies, appointments

CONFIG
  config/database.php          MySQLi → $conn (host:localhost db:rminderdb user:root pass:'')

FUNCTIONS
  functions/system_events.php  generateSystemEvents($conn) — called from dashboard+events

INCLUDES (loaded by every auth page in order)
  includes/header.php          <head>, fixed top bar, notification popup, JS toggles
  includes/sidebar.php         Role-aware nav menu, isActive() helper
  includes/footer.php          Closes .layout div
LAYOUT RULE: main container → margin-left:260px; padding:90px 30px 30px;

PAGES (all require auth unless noted)
  pages/login.php              Public — login form → POST actions/login_action.php
  pages/register.php           Public — register form → POST actions/register_action.php
  pages/dashboard.php          Role stats + activity feed; calls generateSystemEvents()
  pages/events.php             Event list + mini calendar + quick-create; calls generateSystemEvents()
  pages/add_event.php          Dedicated event create form (alternative to quick-create)
  pages/edit_event.php         Edit single event (GET ?id=N)
  pages/announcements.php      Category-tagged announcements + create form (admin/imam only)
  pages/donations.php          Donation + distribution forms and summary table
  pages/attendance.php         Per-event attendance recording (GET ?event_id=N)
  pages/forum.php              Thread list + new thread form
  pages/forum_thread.php       Single thread + replies (GET ?id=N)
  pages/users.php              Admin-only: activate/suspend accounts
  pages/appointments.php       Admin-only: view + filter + update appointment status
  pages/book_appointment.php   PUBLIC (no auth): appointment booking form
  pages/appointment_confirmation.php  PUBLIC: shows reference_no after booking
  pages/communities.php        Community management (admin)
  pages/profile.php            Auth: user profile + stats; tab=profile|security
  pages/settings.php           User settings
  pages/reports.php            Printable: events + attendance + donations tables
  pages/help.php               Help/FAQ page
  pages/export_report.php      Export reports (CSV/print)

ACTIONS (write + redirect, no HTML output)
  actions/login_action.php       bcrypt+MD5 dual verify → sets session → dashboard.php
  actions/register_action.php    bcrypt hash, dupe check → login.php
  actions/logout.php             session_destroy → login.php
  actions/add_event_action.php   INSERT events (prepared)
  actions/update_event.php       UPDATE events (prepared)
  actions/delete_event.php       DELETE events by id
  actions/add_announcement_action.php  Role-guard admin/imam; INSERT announcements (prepared)
  actions/add_donation.php       INSERT donations; donor_name defaults 'Anonymous'
  actions/add_distribution.php   INSERT distributions (prepared)
  actions/add_attendance.php     INSERT attendance (prepared)
  actions/add_thread.php         INSERT forum_threads (prepared)
  actions/add_reply.php          INSERT forum_replies (prepared)
  actions/moderate_thread.php    Admin/imam: pin toggle OR delete thread+replies
  actions/submit_appointment.php Public: generate reference_no, INSERT appointments
  actions/update_appointment.php Admin: UPDATE appointments.status + admin_remarks
  actions/change_password.php    UPDATE users.password (bcrypt)
  actions/update_profile.php     UPDATE users.name/email
  actions/search.php             Search handler

ASSETS
  assets/ramadan.png            Hero image (landing + login pages)


§2 SESSION VARIABLES (set by login_action.php)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
$_SESSION['user_id']      -- users.id (int)
$_SESSION['role']         -- 'admin'|'imam'|'leader'|'viewer'
$_SESSION['community_id'] -- users.community_id (int, 0 for admin)
$_SESSION['name']         -- users.name

AUTH GUARD (every protected page):
  session_start();
  include "../config/database.php";
  if (!isset($_SESSION['user_id'])) { header("Location: login.php"); exit(); }

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
§3 ROLE PERMISSIONS MATRIX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
admin   → all features, all communities, users.php management, appointments.php
imam    → announcements (create), moderate_thread, events, forum, attendance, donations
leader  → events, forum, attendance, donations (no announcements create, no moderation)
viewer  → read-only on most features
COMMUNITY SCOPING: queries filter WHERE community_id = $_SESSION['community_id']
admin exception: sees ALL communities (no community_id filter applied)
system events: community_id IS NULL → visible to everyone

